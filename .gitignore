# Bun / Node
node_modules/
bun.lockb

# Build outputs
dist/
build/
test-results/

# Electrobun runtime cache and build artifacts
.electrobun/
artifacts/

# User data — runtime user data is excluded; test fixtures are tracked
# Note: git cannot re-include subdirs of an ignored parent, so we ignore
# specific runtime subdirs rather than the whole data/ folder.
data/*.ndjson
data/*.db
data/*.db-shm
data/*.db-wal
data/user/

# macOS
.DS_Store
**/.DS_Store

# Editor
.vscode/
*.swp
*.swo

# Environment
.env
.env.local
.env.*.local
