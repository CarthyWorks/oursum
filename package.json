{
	"name": "oursum",
	"version": "0.1.4",
	"type": "module",
	"description": "Oursum — personal expense tracker by CarthyWorks",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build": "vite build && electrobun build --env=dev",
		"test": "bun test src/core/",
		"lint": "bunx eslint src/renderer/ src/shared/ src/core/ --max-warnings 0",
		"lint:types": "bunx tsc -p tsconfig.renderer.json --noEmit",
		"test:e2e": "playwright test",
		"generate-icon": "bun scripts/generate-app-icon.ts",
		"release": "vite build && electrobun build --env=stable && bun scripts/post-release.ts",
		"release:win": "vite build && electrobun build --env=stable && bun scripts/post-release.ts"
	},
	"dependencies": {
		"@radix-ui/react-alert-dialog": "^1.1.15",
		"@radix-ui/react-checkbox": "^1.3.3",
		"@radix-ui/react-context-menu": "^2.2.16",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tooltip": "^1.2.8",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.1.0",
		"electrobun": "^1.16.0",
		"lucide-react": "^1.8.0",
		"papaparse": "^5.5.3",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"tailwind-merge": "^3.5.0",
		"xlsx": "^0.18.5",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@types/bun": "^1.3.12",
		"@types/papaparse": "^5.5.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/three": "^0.183.1",
		"@vitejs/plugin-react": "^6.0.1",
		"@tailwindcss/postcss": "^4.2.2",
		"autoprefixer": "^10.4.27",
		"concurrently": "^9.2.1",
		"eslint": "^10.2.0",
		"postcss": "^8.5.9",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.8"
	}
}
